# Host-side orchestrator config — COPY to .env (gitignored) and fill in.
# These live on the machine that RUNS the orchestrator, never in the repo and
# never in the agent sandbox. In production, source them from a secret manager.

# Drives the Anthropic API / this session:
ANTHROPIC_API_KEY=

# Control-plane IDs (captured from the `ant beta:agents/environments create` calls):
SD_AGENT_ID=
SD_ENVIRONMENT_ID=

# Consumed host-side by custom_tools.py when executing the Controller's tool calls:
DTOOLS_API_KEY=
DTOOLS_BASE_URL=https://dtcloudapi.d-tools.cloud/api/v1
# SMS provider (e.g. Twilio) — Thread 2:
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=
